---
import CodeBlock from "../components/CodeBlock.astro";
import RunsBadge from "../components/RunsBadge.astro";
import DiagramBox from "../components/DiagramBox.astro";
import CompareCards from "../components/CompareCards.astro";
import Callout from "../components/Callout.astro";

const beforeCode = `<span class="text-zinc-400">// No type safety.</span>
<span class="text-zinc-400">// Typo in a column name?</span>
<span class="text-zinc-400">// You won't know until runtime.</span>

<span class="text-violet-300">const </span><span class="text-sky-300">result</span><span class="text-zinc-400"> = </span><span class="text-violet-300">await </span><span class="text-sky-300">pool</span><span class="text-zinc-400">.</span><span class="text-amber-300">query</span><span class="text-zinc-400">(</span>
<span class="text-emerald-400">  \`SELECT id, titl, author
   FROM posts
   WHERE status = $1\`</span><span class="text-zinc-400">,</span>
<span class="text-zinc-400">  [</span><span class="text-emerald-400">'published'</span><span class="text-zinc-400">]</span>
<span class="text-zinc-400">);</span>

<span class="text-zinc-400">// result.rows is \`any[]\`</span>
<span class="text-zinc-400">// "titl" typo? No error.</span>`;

const afterCode = `<span class="text-violet-300">import </span><span class="text-zinc-400">{ </span><span class="text-sky-300">db</span><span class="text-zinc-400"> } </span><span class="text-violet-300">from </span><span class="text-emerald-400">'./db'</span><span class="text-zinc-400">;</span>
<span class="text-violet-300">import </span><span class="text-zinc-400">{ </span><span class="text-sky-300">posts</span><span class="text-zinc-400"> } </span><span class="text-violet-300">from </span><span class="text-emerald-400">'./schema'</span><span class="text-zinc-400">;</span>

<span class="text-violet-300">const </span><span class="text-sky-300">result</span><span class="text-zinc-400"> = </span><span class="text-violet-300">await </span><span class="text-sky-300">db</span><span class="text-zinc-400">.</span><span class="text-amber-300">select</span><span class="text-zinc-400">()</span>
<span class="text-zinc-400">  .</span><span class="text-amber-300">from</span><span class="text-zinc-400">(</span><span class="text-sky-300">posts</span><span class="text-zinc-400">)</span>
<span class="text-zinc-400">  .</span><span class="text-amber-300">where</span><span class="text-zinc-400">(</span>
<span class="text-zinc-400">    </span><span class="text-amber-300">eq</span><span class="text-zinc-400">(</span><span class="text-sky-300">posts</span><span class="text-zinc-400">.</span><span class="text-sky-300">status</span><span class="text-zinc-400">, </span><span class="text-emerald-400">'published'</span><span class="text-zinc-400">));</span>

<span class="text-zinc-400">// result is Post[] — fully typed!</span>
<span class="text-zinc-400">// posts.titl would be a TS error.</span>`;

const drizzleSchemaCode = `<span class="text-violet-300">import </span><span class="text-zinc-400">{ </span><span class="text-sky-300">pgTable, serial, text, timestamp</span><span class="text-zinc-400"> }
  </span><span class="text-violet-300">from </span><span class="text-emerald-400">'drizzle-orm/pg-core'</span><span class="text-zinc-400">;</span>

<span class="text-violet-300">export const </span><span class="text-sky-300">posts</span><span class="text-zinc-400"> = </span><span class="text-amber-300">pgTable</span><span class="text-zinc-400">(</span><span class="text-emerald-400">'posts'</span><span class="text-zinc-400">, {</span>
<span class="text-zinc-400">  </span><span class="text-sky-300">id</span><span class="text-zinc-400">:        </span><span class="text-amber-300">serial</span><span class="text-zinc-400">().</span><span class="text-sky-300">primaryKey</span><span class="text-zinc-400">(),</span>
<span class="text-zinc-400">  </span><span class="text-sky-300">title</span><span class="text-zinc-400">:     </span><span class="text-amber-300">text</span><span class="text-zinc-400">().</span><span class="text-sky-300">notNull</span><span class="text-zinc-400">(),</span>
<span class="text-zinc-400">  </span><span class="text-sky-300">author</span><span class="text-zinc-400">:    </span><span class="text-amber-300">text</span><span class="text-zinc-400">().</span><span class="text-sky-300">notNull</span><span class="text-zinc-400">(),</span>
<span class="text-zinc-400">  </span><span class="text-sky-300">createdAt</span><span class="text-zinc-400">: </span><span class="text-amber-300">timestamp</span><span class="text-zinc-400">().</span><span class="text-sky-300">defaultNow</span><span class="text-zinc-400">(),</span>
<span class="text-zinc-400">});</span>

<span class="text-zinc-400">// TypeScript now knows: a post has id (number),</span>
<span class="text-zinc-400">// title (string), author (string), createdAt (Date).</span>`;

const convexQueryCode = `<span class="text-violet-300">import </span><span class="text-zinc-400">{ </span><span class="text-sky-300">query</span><span class="text-zinc-400"> } </span><span class="text-violet-300">from </span><span class="text-emerald-400">'./_generated/server'</span><span class="text-zinc-400">;</span>

<span class="text-violet-300">export const </span><span class="text-sky-300">listPosts</span><span class="text-zinc-400"> = </span><span class="text-amber-300">query</span><span class="text-zinc-400">({</span>
<span class="text-zinc-400">  </span><span class="text-sky-300">handler</span><span class="text-zinc-400">: </span><span class="text-violet-300">async </span><span class="text-zinc-400">(ctx) =&gt; {</span>
<span class="text-zinc-400">    </span><span class="text-violet-300">return await </span><span class="text-sky-300">ctx</span><span class="text-zinc-400">.</span><span class="text-sky-300">db</span>
<span class="text-zinc-400">      .</span><span class="text-amber-300">query</span><span class="text-zinc-400">(</span><span class="text-emerald-400">"posts"</span><span class="text-zinc-400">)</span>
<span class="text-zinc-400">      .</span><span class="text-amber-300">order</span><span class="text-zinc-400">(</span><span class="text-emerald-400">"desc"</span><span class="text-zinc-400">)</span>
<span class="text-zinc-400">      .</span><span class="text-amber-300">collect</span><span class="text-zinc-400">();</span>
<span class="text-zinc-400">  },</span>
<span class="text-zinc-400">});</span>`;

const convexReactCode = `<span class="text-violet-300">import </span><span class="text-zinc-400">{ </span><span class="text-sky-300">useQuery</span><span class="text-zinc-400"> } </span><span class="text-violet-300">from </span><span class="text-emerald-400">'convex/react'</span><span class="text-zinc-400">;</span>
<span class="text-violet-300">import </span><span class="text-zinc-400">{ </span><span class="text-sky-300">api</span><span class="text-zinc-400"> } </span><span class="text-violet-300">from </span><span class="text-emerald-400">'../convex/_generated/api'</span><span class="text-zinc-400">;</span>

<span class="text-violet-300">function </span><span class="text-amber-300">PostList</span><span class="text-zinc-400">() {</span>
<span class="text-zinc-400">  // Fully typed — knows the return shape</span>
<span class="text-zinc-400">  </span><span class="text-violet-300">const </span><span class="text-sky-300">posts</span><span class="text-zinc-400"> = </span><span class="text-amber-300">useQuery</span><span class="text-zinc-400">(</span><span class="text-sky-300">api</span><span class="text-zinc-400">.</span><span class="text-sky-300">posts</span><span class="text-zinc-400">.</span><span class="text-sky-300">listPosts</span><span class="text-zinc-400">);</span>

<span class="text-zinc-400">  // Data updates in REAL TIME — no refetching needed.</span>
<span class="text-zinc-400">  // Another user adds a post? It appears instantly.</span>
<span class="text-zinc-400">}</span>`;
---

<div class="space-y-8">
  <div class="flex flex-wrap gap-3 items-center">
    <RunsBadge location="Your Server" color="emerald" />
  </div>

  <p class="text-lg leading-relaxed text-zinc-300">
    You know what a database is from your CS classes. But in web dev, you rarely
    write raw SQL strings. Instead, you use a
    <strong class="text-indigo-300">query builder</strong> or
    <strong class="text-indigo-300">ORM</strong> (Object-Relational Mapper) that lets
    you write type-safe queries in TypeScript — so your editor catches mistakes before
    they hit production.
  </p>

  <CompareCards
    beforeLabel="Raw SQL strings"
    afterLabel="Drizzle ORM (type-safe)"
    accentBefore="border-zinc-700 bg-zinc-900/50"
    accentAfter="border-indigo-900/40 bg-indigo-950/10"
  >
    <Fragment slot="before">
      <CodeBlock title="api/posts.ts">
        <Fragment set:html={beforeCode} />
      </CodeBlock>
    </Fragment>
    <Fragment slot="after">
      <CodeBlock title="api/posts.ts" accent="violet">
        <Fragment set:html={afterCode} />
      </CodeBlock>
    </Fragment>
  </CompareCards>

  {/* Drizzle */}
  <div class="space-y-4">
    <h3 class="font-display font-bold text-indigo-300 text-xl">Drizzle ORM</h3>
    <p class="text-zinc-400 leading-relaxed">
      <strong class="text-indigo-200">Drizzle</strong> is a TypeScript ORM that maps
      closely to SQL — if you know SQL, you already know Drizzle. You define your
      tables as TypeScript schemas, and Drizzle generates types from them. Queries
      look like SQL but with full autocomplete and type checking.
    </p>

    <CodeBlock
      title="schema.ts — define your tables in TypeScript"
      accent="violet"
    >
      <Fragment set:html={drizzleSchemaCode} />
    </CodeBlock>

    <div class="grid sm:grid-cols-3 gap-3">
      {
        [
          {
            label: "SQL-like",
            desc: "Queries mirror SQL so closely that knowing one means knowing the other. No new query language to learn.",
          },
          {
            label: "Type-safe",
            desc: "Schema generates TypeScript types. Mistype a column? Your editor catches it instantly.",
          },
          {
            label: "Lightweight",
            desc: "Thin layer over SQL — no heavy abstraction. You see exactly what query runs.",
          },
        ].map((f) => (
          <div class="rounded-lg border border-indigo-900/30 bg-indigo-950/10 p-3">
            <div class="font-mono text-xs font-bold text-indigo-300 mb-1">
              {f.label}
            </div>
            <p class="text-xs text-zinc-400 leading-relaxed">{f.desc}</p>
          </div>
        ))
      }
    </div>
  </div>

  {/* Convex */}
  <div class="space-y-4">
    <h3 class="font-display font-bold text-indigo-300 text-xl">
      Convex: A Different Approach
    </h3>
    <p class="text-zinc-400 leading-relaxed">
      <strong class="text-indigo-200">Convex</strong> takes a completely different
      approach. Instead of connecting to a database and writing queries yourself,
      Convex <em>is</em> the backend. You write TypeScript functions that Convex runs
      on its servers — no SQL, no database setup, no connection strings.
    </p>

    <CodeBlock title="convex/posts.ts — server-side function" accent="violet">
      <Fragment set:html={convexQueryCode} />
    </CodeBlock>

    <CodeBlock title="src/PostList.tsx — in your React app" accent="violet">
      <Fragment set:html={convexReactCode} />
    </CodeBlock>

    <div class="grid sm:grid-cols-3 gap-3">
      {
        [
          {
            label: "No SQL",
            desc: "Query with TypeScript, not SQL strings. The API is designed for TypeScript-first developers.",
          },
          {
            label: "Real-time",
            desc: "Data syncs live to all connected clients. No polling, no WebSocket setup — it's built in.",
          },
          {
            label: "No infra to manage",
            desc: "No database to provision, no connection strings, no migrations server. Convex handles it all.",
          },
        ].map((f) => (
          <div class="rounded-lg border border-indigo-900/30 bg-indigo-950/10 p-3">
            <div class="font-mono text-xs font-bold text-indigo-300 mb-1">
              {f.label}
            </div>
            <p class="text-xs text-zinc-400 leading-relaxed">{f.desc}</p>
          </div>
        ))
      }
    </div>
  </div>

  {/* Where it runs */}
  <DiagramBox>
    <div class="text-center mb-4">
      <span class="text-xs font-mono text-zinc-400 uppercase tracking-widest">
        Traditional ORM vs Convex
      </span>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      <div
        class="rounded-xl border border-zinc-700 bg-zinc-900/50 p-4 space-y-3"
      >
        <div class="font-display font-bold text-zinc-200">
          Drizzle / Prisma / raw SQL
        </div>
        <div class="space-y-2 text-xs font-mono text-zinc-400">
          <div class="rounded bg-zinc-800/60 px-3 py-1.5">
            React app (browser)
          </div>
          <div class="text-zinc-500 text-center">&darr;&uarr; HTTP / JSON</div>
          <div class="rounded bg-zinc-800/60 px-3 py-1.5">
            Your API server (Express, Hono, etc.)
          </div>
          <div class="text-zinc-500 text-center">&darr;&uarr; SQL</div>
          <div class="rounded bg-zinc-800/60 px-3 py-1.5">
            PostgreSQL / MySQL / SQLite
          </div>
        </div>
        <p class="text-xs text-zinc-400">
          You manage the API server and database yourself.
        </p>
      </div>

      <div
        class="rounded-xl border border-indigo-800/40 bg-indigo-950/10 p-4 space-y-3"
      >
        <div class="font-display font-bold text-indigo-200">Convex</div>
        <div class="space-y-2 text-xs font-mono text-zinc-400">
          <div class="rounded bg-zinc-800/60 px-3 py-1.5">
            React app (browser)
          </div>
          <div class="text-indigo-500 text-center">
            &darr;&uarr; WebSocket (real-time)
          </div>
          <div
            class="rounded bg-indigo-950/40 border border-indigo-800/30 px-3 py-1.5 text-indigo-300"
          >
            Convex cloud (functions + database)
          </div>
        </div>
        <p class="text-xs text-zinc-400">
          Convex is both your API and your database. One fewer thing to manage.
        </p>
      </div>
    </div>
  </DiagramBox>

  <Callout color="#818cf8" icon="🔑">
    <strong class="text-indigo-300">
      All database code runs on the server, never in the browser.
    </strong>
    Whether you use Drizzle, Convex, or raw SQL — the browser never touches your database
    directly. With Drizzle, your API server runs the queries. With Convex, their cloud
    runs the queries. Either way, the React app in the browser only communicates via
    HTTP or WebSocket.
  </Callout>

  <Callout color="#818cf8" icon="💡">
    <strong class="text-indigo-300">Which should you pick?</strong> If you want full
    control and already know SQL,
    <strong class="text-indigo-200">Drizzle</strong> gives you type-safe queries with
    minimal abstraction. If you want to skip backend/database setup entirely and get
    real-time sync for free,
    <strong class="text-indigo-200">Convex</strong> handles the infrastructure so
    you can focus on your app. Both are excellent choices — it depends on how much
    control vs convenience you want.
  </Callout>
</div>
