---
import RunsBadge from "../components/RunsBadge.astro";
import DiagramBox from "../components/DiagramBox.astro";
import Callout from "../components/Callout.astro";
---

<div class="space-y-8">
  <p class="text-lg leading-relaxed text-zinc-300">
    JavaScript was born in the browser in 1995. For years, that was the <em
      >only</em
    > place it could run. Then <strong class="text-sky-300">Node.js</strong> came
    along in 2009 and changed everything — it let you run JavaScript on servers, on
    your laptop, anywhere. A <strong class="text-sky-300">runtime</strong> is the
    engine that actually executes your JavaScript code.
  </p>

  <DiagramBox>
    <div class="text-center mb-6">
      <span class="text-xs font-mono text-zinc-400 uppercase tracking-widest">
        Two different worlds, same language
      </span>
    </div>
    <div class="grid md:grid-cols-2 gap-6">
      <div
        class="rounded-xl border-2 border-sky-700/50 bg-sky-950/20 p-5 space-y-4"
      >
        <div class="flex items-center gap-2">
          <span class="text-2xl">🖥️</span>
          <h3 class="font-display font-bold text-sky-300 text-lg">
            Your Machine / Server
          </h3>
        </div>
        <RunsBadge location="Your Machine" color="cyan" />
        <div class="space-y-2 mt-3">
          {
            [
              {
                name: "Node.js",
                desc: "The OG. Uses Chrome's V8 engine. Massive ecosystem (npm).",
              },
              {
                name: "Bun",
                desc: "The new kid. Blazingly fast. Built-in bundler, test runner, package manager.",
              },
              {
                name: "Deno",
                desc: "Made by Node's creator. TypeScript built-in. Security-focused.",
              },
            ].map((rt) => (
              <div class="rounded-lg bg-sky-950/40 border border-sky-900/40 p-3">
                <span class="font-mono text-sm font-bold text-sky-200">
                  {rt.name}
                </span>
                <p class="text-xs text-zinc-400 mt-0.5">{rt.desc}</p>
              </div>
            ))
          }
        </div>
        <div
          class="text-xs text-zinc-400 font-mono mt-3 pt-3 border-t border-sky-900/30"
        >
          Can access: file system, network, databases, processes
          <br />
          Cannot access: DOM, window, document
        </div>
      </div>

      <div
        class="rounded-xl border-2 border-violet-700/50 bg-violet-950/20 p-5 space-y-4"
      >
        <div class="flex items-center gap-2">
          <span class="text-2xl">🌐</span>
          <h3 class="font-display font-bold text-violet-300 text-lg">
            User's Web Browser
          </h3>
        </div>
        <RunsBadge location="User's Browser" color="violet" />
        <div class="space-y-2 mt-3">
          {
            [
              {
                name: "V8",
                desc: "Chrome, Edge, Opera, Brave. Google's JS engine.",
              },
              {
                name: "SpiderMonkey",
                desc: "Firefox. Mozilla's engine. The original JS engine.",
              },
              {
                name: "JavaScriptCore",
                desc: "Safari. Apple's engine (also called Nitro).",
              },
            ].map((rt) => (
              <div class="rounded-lg bg-violet-950/40 border border-violet-900/40 p-3">
                <span class="font-mono text-sm font-bold text-violet-200">
                  {rt.name}
                </span>
                <p class="text-xs text-zinc-400 mt-0.5">{rt.desc}</p>
              </div>
            ))
          }
        </div>
        <div
          class="text-xs text-zinc-400 font-mono mt-3 pt-3 border-t border-violet-900/30"
        >
          Can access: DOM, window, fetch, localStorage
          <br />
          Cannot access: file system, databases, processes
        </div>
      </div>
    </div>
  </DiagramBox>

  <div class="grid md:grid-cols-2 gap-6">
    <Callout color="#38bdf8" icon="⚡">
      <strong class="text-sky-300">When you run</strong>
      <code class="font-mono text-sky-200 bg-sky-950/50 px-1.5 rounded"
        >npm run dev</code
      > — that's <strong>Node.js</strong> (a JS runtime) running on your laptop. It
      starts the Vite dev server, watches your files, and serves your app to the browser.
    </Callout>

    <Callout color="#a78bfa" icon="🌐">
      <strong class="text-violet-300">When a user opens your app</strong> — their
      browser's built-in JS engine (V8, SpiderMonkey, etc.) executes the JavaScript
      bundle that Vite produced. Completely separate from your machine.
    </Callout>
  </div>

  <Callout color="#38bdf8" icon="🧠">
    <strong class="text-sky-300">Why this matters:</strong> Same language (JavaScript),
    but different environments with different capabilities. Code that reads files
    from disk (<code class="font-mono text-xs bg-zinc-800 px-1 rounded"
      >fs.readFile</code
    >) works in Node/Bun but will crash in a browser. Code that manipulates the
    page (<code class="font-mono text-xs bg-zinc-800 px-1 rounded"
      >document.querySelector</code
    >) works in browsers but not in Node/Bun.
  </Callout>
</div>
