---
import CodeBlock from "../components/CodeBlock.astro";
import RunsBadge from "../components/RunsBadge.astro";
import CompareCards from "../components/CompareCards.astro";
import Callout from "../components/Callout.astro";
import DiagramBox from "../components/DiagramBox.astro";

const beforeCode = `<span class="text-violet-300">function </span><span class="text-amber-300">add</span><span class="text-zinc-400">(a, b) {
  </span><span class="text-violet-300">return </span><span class="text-zinc-400">a + b;
}

</span><span class="text-amber-300">add</span><span class="text-zinc-400">(</span><span class="text-emerald-400">5</span><span class="text-zinc-400">, </span><span class="text-emerald-400">"3"</span><span class="text-zinc-400">);
</span><span class="text-zinc-400">// Returns "53" not 8!</span><span class="text-zinc-400">
</span><span class="text-zinc-400">// JS silently concatenated
</span><span class="text-zinc-400">// strings instead of adding.
</span><span class="text-zinc-400">// No error. Just wrong.</span>`;

const afterCode = `<span class="text-violet-300">function </span><span class="text-amber-300">add</span><span class="text-zinc-400">(</span><span class="text-sky-300">a</span><span class="text-zinc-400">: </span><span class="text-pink-300">number</span><span class="text-zinc-400">, </span><span class="text-sky-300">b</span><span class="text-zinc-400">: </span><span class="text-pink-300">number</span><span class="text-zinc-400">) {
  </span><span class="text-violet-300">return </span><span class="text-zinc-400">a + b;
}

</span><span class="text-amber-300">add</span><span class="text-zinc-400">(</span><span class="text-emerald-400">5</span><span class="text-zinc-400">, </span><span class="text-red-400">"3"</span><span class="text-zinc-400">);
</span><span class="text-red-400">// ❌ Error: Argument of
</span><span class="text-red-400">// type 'string' is not
</span><span class="text-red-400">// assignable to 'number'.
</span><span class="text-zinc-400">// Caught BEFORE running!</span>`;

const typesCode = `<span class="text-zinc-400">// This describes what a Post looks like.
</span><span class="text-zinc-400">// It doesn't create anything — it's just a blueprint.

</span><span class="text-violet-300">interface </span><span class="text-pink-300">Post</span><span class="text-zinc-400"> {
  </span><span class="text-sky-300">id</span><span class="text-zinc-400">: </span><span class="text-pink-300">number</span><span class="text-zinc-400">;
  </span><span class="text-sky-300">title</span><span class="text-zinc-400">: </span><span class="text-pink-300">string</span><span class="text-zinc-400">;
  </span><span class="text-sky-300">body</span><span class="text-zinc-400">: </span><span class="text-pink-300">string</span><span class="text-zinc-400">;
  </span><span class="text-sky-300">author</span><span class="text-zinc-400">: </span><span class="text-pink-300">string</span><span class="text-zinc-400">;
  </span><span class="text-sky-300">createdAt</span><span class="text-zinc-400">: </span><span class="text-pink-300">Date</span><span class="text-zinc-400">;
}</span>`;

const postCardCode = `<span class="text-violet-300">function </span><span class="text-amber-300">PostCard</span><span class="text-zinc-400">({ </span><span class="text-sky-300">post</span><span class="text-zinc-400"> }: { </span><span class="text-sky-300">post</span><span class="text-zinc-400">: </span><span class="text-pink-300">Post</span><span class="text-zinc-400"> }) {
  </span><span class="text-violet-300">return </span><span class="text-zinc-400">(
    &lt;</span><span class="text-red-400">div</span><span class="text-zinc-400">&gt;
      &lt;</span><span class="text-red-400">h2</span><span class="text-zinc-400">&gt;{post.</span><span class="text-sky-300">title</span><span class="text-zinc-400">}&lt;/</span><span class="text-red-400">h2</span><span class="text-zinc-400">&gt;
      &lt;</span><span class="text-red-400">p</span><span class="text-zinc-400">&gt;{post.</span><span class="text-sky-300">body</span><span class="text-zinc-400">}&lt;/</span><span class="text-red-400">p</span><span class="text-zinc-400">&gt;
      &lt;</span><span class="text-red-400">span</span><span class="text-zinc-400">&gt;By {post.</span><span class="text-sky-300">author</span><span class="text-zinc-400">}&lt;/</span><span class="text-red-400">span</span><span class="text-zinc-400">&gt;

      {post.</span><span class="text-red-400">naem</span><span class="text-zinc-400">}
</span><span class="text-red-400">      // ❌ Error: Property 'naem'
</span><span class="text-red-400">      // does not exist on type 'Post'.
</span><span class="text-red-400">      // Did you mean 'name'?
</span><span class="text-zinc-400">    &lt;/</span><span class="text-red-400">div</span><span class="text-zinc-400">&gt;
  );
}</span>`;
---

<div class="space-y-8">
  <div class="flex flex-wrap gap-3 items-center">
    <RunsBadge location="Build Time (your machine)" color="amber" />
  </div>

  <p class="text-lg leading-relaxed text-zinc-300">
    JavaScript is <em>dynamically typed</em> — a variable can be a number one moment
    and a string the next. This flexibility is great for small scripts, but in a large
    app it leads to bugs that are hard to track down. <strong
      class="text-pink-300">TypeScript</strong
    > is JavaScript with types added on top. It catches mistakes <em>before</em> your
    code runs.
  </p>

  {/* Before/After */}
  <CompareCards
    beforeLabel="JavaScript — runtime surprise"
    afterLabel="TypeScript — caught at build time"
    accentBefore="border-zinc-700 bg-zinc-900/50"
    accentAfter="border-pink-900/40 bg-pink-950/10"
  >
    <Fragment slot="before">
      <CodeBlock title="utils.js">
        <Fragment set:html={beforeCode} />
      </CodeBlock>
    </Fragment>
    <Fragment slot="after">
      <CodeBlock title="utils.ts" accent="rose">
        <Fragment set:html={afterCode} />
      </CodeBlock>
    </Fragment>
  </CompareCards>

  <p class="text-zinc-400 leading-relaxed">
    TypeScript is a <strong class="text-pink-200">superset</strong> of JavaScript
    — every valid JS file is already valid TS. You just <em>add</em> type annotations
    where you want them. The TypeScript compiler strips the types away and outputs
    plain JavaScript that the browser can run.
  </p>

  {/* How it works */}
  <DiagramBox>
    <div class="text-center mb-4">
      <span class="text-xs font-mono text-zinc-400 uppercase tracking-widest">
        TypeScript compilation
      </span>
    </div>
    <div class="flex flex-col md:flex-row items-center gap-6 justify-center">
      <div class="flex flex-col gap-2">
        {
          [
            { name: "App.tsx", desc: "React + types" },
            { name: "utils.ts", desc: "Logic + types" },
            { name: "api.ts", desc: "API calls + types" },
          ].map((f) => (
            <div class="px-3 py-1.5 rounded border border-pink-800/40 bg-pink-950/20 text-xs font-mono flex items-center gap-3">
              <span class="text-pink-300">{f.name}</span>
              <span class="text-zinc-500">{f.desc}</span>
            </div>
          ))
        }
      </div>

      <div class="text-pink-400 text-3xl md:rotate-0 rotate-90">⟹</div>

      <div
        class="px-6 py-4 rounded-2xl bg-pink-950/30 border-2 border-pink-700/40 text-center"
      >
        <div class="text-3xl mb-1">🔍</div>
        <div class="font-display font-bold text-pink-300">TypeScript</div>
        <div class="text-xs text-zinc-400 mt-1">Type checks → strips types</div>
      </div>

      <div class="text-pink-400 text-3xl md:rotate-0 rotate-90">⟹</div>

      <div class="flex flex-col gap-2">
        {
          [
            { name: "App.js", desc: "Plain JS" },
            { name: "utils.js", desc: "Plain JS" },
            { name: "api.js", desc: "Plain JS" },
          ].map((f) => (
            <div class="px-3 py-1.5 rounded border border-zinc-700 bg-zinc-800/60 text-xs font-mono flex items-center gap-3">
              <span class="text-zinc-300">{f.name}</span>
              <span class="text-zinc-500">{f.desc}</span>
            </div>
          ))
        }
      </div>
    </div>
  </DiagramBox>

  {/* A more realistic example */}
  <div class="space-y-4">
    <h3 class="font-display font-bold text-pink-300 text-xl">
      A Real-World Example
    </h3>
    <p class="text-zinc-400 leading-relaxed">
      Types really shine when working with data from an API. Without types,
      you're guessing what fields exist on an object. With types, your editor
      tells you <em>exactly</em> what's available.
    </p>

    <CodeBlock title="types.ts — define the shape of your data" accent="rose">
      <Fragment set:html={typesCode} />
    </CodeBlock>

    <CodeBlock
      title="PostCard.tsx — your editor now knows every field"
      accent="rose"
    >
      <Fragment set:html={postCardCode} />
    </CodeBlock>
  </div>

  {/* File extensions */}
  <div class="space-y-4">
    <h3 class="font-display font-bold text-pink-300 text-xl">
      File Extensions: The Complete Picture
    </h3>
    <p class="text-zinc-400 leading-relaxed">
      Now you can understand all four extensions and when to use each one.
    </p>
    <div class="grid sm:grid-cols-2 gap-4">
      {
        [
          {
            ext: ".js",
            name: "JavaScript",
            desc: "Plain JavaScript. No JSX, no types. Use for utility functions, config files, constants.",
            example: "utils.js, config.js, api.js",
            color: "#fbbf24",
          },
          {
            ext: ".jsx",
            name: "JavaScript + JSX",
            desc: "JavaScript that contains JSX (HTML-like syntax). Use for React components written without TypeScript.",
            example: "App.jsx, Header.jsx, Button.jsx",
            color: "#a78bfa",
          },
          {
            ext: ".ts",
            name: "TypeScript",
            desc: "JavaScript with type annotations. No JSX. Use for utility functions, API helpers, type definitions.",
            example: "utils.ts, types.ts, api.ts",
            color: "#fb7185",
          },
          {
            ext: ".tsx",
            name: "TypeScript + JSX",
            desc: "The full package — typed JavaScript with JSX. Use for React components with TypeScript. This is what most modern React projects use.",
            example: "App.tsx, Header.tsx, Button.tsx",
            color: "#f472b6",
          },
        ].map((f) => (
          <div
            class="rounded-xl border p-5 space-y-2"
            style={`border-color: ${f.color}35; background-color: ${f.color}08;`}
          >
            <div class="flex items-center gap-3">
              <code
                class="font-mono text-xl font-bold"
                style={`color: ${f.color};`}
              >
                {f.ext}
              </code>
              <span class="text-sm text-zinc-400">{f.name}</span>
            </div>
            <p class="text-sm text-zinc-400 leading-relaxed">{f.desc}</p>
            <div class="text-xs font-mono text-zinc-500">e.g. {f.example}</div>
          </div>
        ))
      }
    </div>
  </div>

  <Callout color="#fb7185" icon="🔑">
    <strong class="text-pink-300">
      TypeScript doesn't run in the browser.
    </strong> Just like Tailwind, TypeScript is a <strong
      >build-time tool</strong
    >. Vite (via its bundler) strips all the type annotations out and produces
    plain JavaScript. The browser receives normal <code
      class="font-mono text-xs bg-zinc-800 px-1 rounded">.js</code
    > — it has no idea you wrote TypeScript.
  </Callout>
</div>
