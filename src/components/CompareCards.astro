---
interface Props {
  beforeLabel?: string;
  afterLabel?: string;
  accentBefore?: string;
  accentAfter?: string;
}

const { beforeLabel, afterLabel, accentBefore, accentAfter } = Astro.props;
---

<div class="grid md:grid-cols-2 gap-4">
  <div
    class={`rounded-xl border p-5 ${accentBefore || "border-red-900/50 bg-red-950/20"}`}
  >
    <div
      class="text-xs font-semibold font-mono uppercase tracking-wider text-red-400 mb-3"
    >
      {beforeLabel || "Before"}
    </div>
    <slot name="before" />
  </div>
  <div
    class={`rounded-xl border p-5 ${accentAfter || "border-emerald-900/50 bg-emerald-950/20"}`}
  >
    <div
      class="text-xs font-semibold font-mono uppercase tracking-wider text-emerald-400 mb-3"
    >
      {afterLabel || "After"}
    </div>
    <slot name="after" />
  </div>
</div>
