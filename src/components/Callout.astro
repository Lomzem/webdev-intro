---
interface Props {
  color?: string;
  icon?: string;
}

const { color = "#fbbf24", icon = "💡" } = Astro.props;
---

<div
  class="rounded-xl border px-5 py-4 flex gap-3"
  style={`border-color: ${color}30; background-color: ${color}08;`}
>
  <span class="text-xl flex-shrink-0">{icon}</span>
  <div class="text-sm leading-relaxed text-zinc-300 min-w-0"><slot /></div>
</div>
