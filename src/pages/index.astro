---
import Layout from "../layouts/Layout.astro";
import OldDays from "../sections/OldDays.astro";
import Runtimes from "../sections/Runtimes.astro";
import PackageManagers from "../sections/PackageManagers.astro";
import Bundlers from "../sections/Bundlers.astro";
import Frameworks from "../sections/Frameworks.astro";
import TypeScript from "../sections/TypeScript.astro";
import TailwindCSS from "../sections/TailwindCSS.astro";
import DataFetching from "../sections/DataFetching.astro";
import Fullstack from "../sections/Fullstack.astro";
import Databases from "../sections/Databases.astro";
import Architecture from "../sections/Architecture.astro";

const sections = [
  {
    id: "old-days",
    num: "01",
    title: "The Old Days",
    subtitle: "Raw HTML, CSS & JS",
    color: "#fbbf24",
  },
  {
    id: "runtimes",
    num: "02",
    title: "JS Runtimes",
    subtitle: "Node, Bun & Deno",
    color: "#38bdf8",
  },
  {
    id: "package-managers",
    num: "03",
    title: "Package Managers",
    subtitle: "npm, pnpm & bun",
    color: "#a3e635",
  },
  {
    id: "bundlers",
    num: "04",
    title: "Bundlers",
    subtitle: "Vite & Webpack",
    color: "#34d399",
  },
  {
    id: "frameworks",
    num: "05",
    title: "Frontend Frameworks",
    subtitle: "React, Vue & Svelte",
    color: "#a78bfa",
  },
  {
    id: "typescript",
    num: "06",
    title: "TypeScript",
    subtitle: "Types for JavaScript",
    color: "#fb7185",
  },
  {
    id: "tailwind",
    num: "07",
    title: "CSS Frameworks",
    subtitle: "Tailwind CSS",
    color: "#f472b6",
  },
  {
    id: "data-fetching",
    num: "08",
    title: "Data Fetching",
    subtitle: "TanStack Query",
    color: "#fb923c",
  },
  {
    id: "fullstack",
    num: "09",
    title: "Fullstack Frameworks",
    subtitle: "Next.js, Remix & SSR",
    color: "#2dd4bf",
  },
  {
    id: "databases",
    num: "10",
    title: "Databases & ORMs",
    subtitle: "Drizzle, Convex & SQL",
    color: "#c084fc",
  },
  {
    id: "architecture",
    num: "11",
    title: "Putting It Together",
    subtitle: "The Full Picture",
    color: "#60a5fa",
  },
];
---

<Layout
  title="Web Dev Fundamentals"
  description="An interactive guide that explains modern web development concepts — bundlers, frameworks, runtimes, TypeScript, and more — for CS students with no prior web experience."
>
  <div class="noise-bg min-h-screen bg-zinc-950">
    <!-- Mobile header -->
    <div
      class="lg:hidden fixed top-0 left-0 right-0 z-50 bg-zinc-950/90 backdrop-blur-xl border-b border-zinc-800/50"
    >
      <div class="flex items-center gap-3 px-4 py-3">
        <button
          id="menu-toggle"
          aria-label="Open menu"
          class="p-2 -ml-2 rounded-lg hover:bg-zinc-800 transition-colors"
        >
          <svg
            id="menu-icon-open"
            class="w-5 h-5 text-zinc-400"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
          <svg
            id="menu-icon-close"
            class="w-5 h-5 text-zinc-400 hidden"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
        <div class="flex items-center gap-2">
          <span class="text-lg">⚡</span>
          <span class="font-display font-bold text-sm text-zinc-200"
            >Web Fundamentals</span
          >
        </div>
      </div>
    </div>

    <!-- Mobile sidebar overlay -->
    <div
      id="sidebar-overlay"
      class="lg:hidden fixed inset-0 z-40 bg-black/60 backdrop-blur-sm hidden"
    >
    </div>

    <!-- Sidebar -->
    <aside
      id="sidebar"
      class="fixed top-0 left-0 h-screen w-72 bg-zinc-950/95 backdrop-blur-xl border-r border-zinc-800/50 z-50 flex flex-col transition-transform duration-300 -translate-x-full lg:translate-x-0"
    >
      <!-- Logo area -->
      <div class="p-6 pb-4 border-b border-zinc-800/50">
        <div class="flex items-center gap-2.5 mb-1">
          <div
            class="w-8 h-8 rounded-lg bg-gradient-to-br from-violet-500 to-blue-600 flex items-center justify-center"
          >
            <span class="text-white text-sm font-bold">⚡</span>
          </div>
          <div>
            <div
              class="font-display font-bold text-zinc-100 text-sm leading-tight"
            >
              Web Dev
            </div>
            <div
              class="font-display font-bold text-zinc-100 text-sm leading-tight"
            >
              Fundamentals
            </div>
          </div>
        </div>
        <p class="text-[11px] text-zinc-500 mt-2 font-mono">
          A guide for CS students
        </p>
      </div>

      <!-- Navigation -->
      <nav class="flex-1 overflow-y-auto p-3 space-y-0.5">
        {
          sections.map((section) => (
            <button
              class="nav-btn w-full text-left px-3 py-2.5 rounded-xl transition-all duration-200 group flex items-center gap-3 hover:bg-zinc-900 cursor-pointer"
              data-section={section.id}
              data-color={section.color}
            >
              <span class="nav-num font-mono text-[10px] font-bold w-5 flex-shrink-0 transition-colors text-zinc-600">
                {section.num}
              </span>
              <div class="min-w-0">
                <div class="nav-title text-sm font-semibold truncate transition-colors text-zinc-500">
                  {section.title}
                </div>
                <div class="text-[11px] text-zinc-500 truncate">
                  {section.subtitle}
                </div>
              </div>
              <div class="nav-dot ml-auto w-1.5 h-1.5 rounded-full flex-shrink-0 hidden" />
            </button>
          ))
        }
      </nav>

      <!-- Footer -->
      <div class="p-4 border-t border-zinc-800/50 space-y-3">
        <a
          href="https://github.com/Lomzem"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-center gap-2.5"
        >
          <img
            src="https://github.com/Lomzem.png?s=112"
            alt="Lawjay Lee"
            width="28"
            height="28"
            class="w-7 h-7 rounded-full border border-zinc-800 group-hover:border-violet-500/60 transition-colors"
          />
          <div class="min-w-0">
            <div
              class="text-xs font-semibold text-zinc-400 group-hover:text-zinc-200 transition-colors truncate"
            >
              Lawjay Lee
            </div>
            <div
              class="text-[10px] font-mono text-zinc-500 group-hover:text-violet-400/70 transition-colors"
            >
              @Lomzem
            </div>
          </div>
        </a>
        <a
          href="https://github.com/Lomzem/webdev-intro"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 text-[10px] font-mono text-zinc-500 hover:text-zinc-400 transition-colors"
        >
          <svg
            class="w-3 h-3 flex-shrink-0"
            fill="currentColor"
            viewBox="0 0 24 24"
          >
            <path
              d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
            ></path>
          </svg>
          Lomzem/webdev-intro
        </a>
        <p class="text-[10px] text-zinc-600 font-mono leading-relaxed">
          Built with Astro + Tailwind
        </p>
      </div>
    </aside>

    <!-- Main content -->
    <main class="lg:ml-72 pt-14 lg:pt-0">
      <!-- Hero -->
      <div class="relative overflow-hidden">
        <div
          class="absolute inset-0 bg-gradient-to-b from-violet-950/30 via-zinc-950 to-zinc-950"
        >
        </div>
        <div
          class="absolute inset-0 bg-[radial-gradient(ellipse_at_top,_var(--tw-gradient-stops))] from-blue-900/20 via-transparent to-transparent"
        >
        </div>
        <div
          class="relative max-w-4xl mx-auto px-6 pt-20 pb-16 lg:pt-28 lg:pb-20"
        >
          <div class="animate-fade-up">
            <div
              class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-zinc-800/60 border border-zinc-700/50 text-xs font-mono text-zinc-400 mb-6"
            >
              <span class="w-2 h-2 rounded-full bg-emerald-400 animate-pulse"
              ></span>
              For sophomore CS students
            </div>
            <h1
              class="font-display font-extrabold text-4xl sm:text-5xl lg:text-6xl text-white leading-[1.1] mb-6"
            >
              Modern Web Dev<br />
              <span
                class="bg-gradient-to-r from-violet-400 via-blue-400 to-emerald-400 bg-clip-text text-transparent"
                >Demystified</span
              >
            </h1>
            <p class="text-lg text-zinc-400 max-w-2xl leading-relaxed">
              You know how to code. You've written C++, Python, maybe Java. But
              web development feels like a different universe — bundlers,
              frameworks, runtimes, SSR. This guide explains
              <strong class="text-zinc-200"> what</strong> each piece does,
              <strong class="text-zinc-200"> why</strong> it exists, and most importantly,
              <strong class="text-zinc-200"> where it runs</strong>.
            </p>
            <div
              class="mt-8 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-zinc-600"
            >
              <a
                href="https://github.com/Lomzem"
                target="_blank"
                rel="noopener noreferrer"
                class="group inline-flex items-center gap-2 transition-colors"
              >
                <img
                  src="https://github.com/Lomzem.png?s=112"
                  alt="Lawjay Lee"
                  width="20"
                  height="20"
                  class="w-5 h-5 rounded-full border border-zinc-800 group-hover:border-violet-500/60 transition-colors"
                />
                <span
                  class="font-medium text-zinc-400 group-hover:text-zinc-200 transition-colors"
                  >Lawjay Lee</span
                >
                <span
                  class="font-mono text-zinc-500 group-hover:text-violet-400/70 transition-colors"
                  >@Lomzem</span
                >
              </a>
              <span class="text-zinc-600">&middot;</span>
              <a
                href="https://github.com/Lomzem/webdev-intro"
                target="_blank"
                rel="noopener noreferrer"
                class="font-mono text-xs text-zinc-500 hover:text-zinc-400 transition-colors"
              >
                github.com/Lomzem/webdev-intro
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Sections -->
      <div class="max-w-4xl mx-auto px-6 pb-24 space-y-0">
        {
          sections.map((section, idx) => (
            <section id={section.id} class="scroll-mt-20 pt-20 pb-8">
              {/* Section header */}
              <div class="mb-8">
                <div class="flex items-center gap-3 mb-3">
                  <span
                    class="font-mono text-xs font-bold px-2.5 py-1 rounded-md"
                    style={`color: ${section.color}; background-color: ${section.color}15;`}
                  >
                    {section.num}
                  </span>
                  <div
                    class="flex-1 h-px"
                    style={`background: linear-gradient(to right, ${section.color}30, transparent);`}
                  />
                </div>
                <h2
                  class="font-display font-extrabold text-3xl sm:text-4xl"
                  style={`color: ${section.color};`}
                >
                  {section.title}
                </h2>
                <p class="text-zinc-400 mt-1 font-medium">{section.subtitle}</p>
              </div>

              {/* Section content */}
              {idx === 0 && <OldDays />}
              {idx === 1 && <Runtimes />}
              {idx === 2 && <PackageManagers />}
              {idx === 3 && <Bundlers />}
              {idx === 4 && <Frameworks />}
              {idx === 5 && <TypeScript />}
              {idx === 6 && <TailwindCSS />}
              {idx === 7 && <DataFetching />}
              {idx === 8 && <Fullstack />}
              {idx === 9 && <Databases />}
              {idx === 10 && <Architecture />}

              {/* Divider */}
              {idx < sections.length - 1 && (
                <div class="mt-16 flex justify-center">
                  <div class="flex gap-1.5">
                    <div class="w-1.5 h-1.5 rounded-full bg-zinc-800" />
                    <div class="w-1.5 h-1.5 rounded-full bg-zinc-800" />
                    <div class="w-1.5 h-1.5 rounded-full bg-zinc-800" />
                  </div>
                </div>
              )}
            </section>
          ))
        }
      </div>

      <!-- Footer -->
      <footer class="border-t border-zinc-800/50 py-16 px-6">
        <div class="max-w-4xl mx-auto flex flex-col items-center gap-5">
          <a
            href="https://github.com/Lomzem"
            target="_blank"
            rel="noopener noreferrer"
            class="group flex flex-col items-center gap-3"
          >
            <img
              src="https://github.com/Lomzem.png?s=112"
              alt="Lawjay Lee"
              width="56"
              height="56"
              class="w-14 h-14 rounded-full border-2 border-zinc-800 group-hover:border-violet-500/60 transition-all duration-300 group-hover:scale-105"
            />
            <div class="flex flex-col items-center">
              <span
                class="text-sm font-semibold text-zinc-300 group-hover:text-white transition-colors"
                >Lawjay Lee</span
              >
              <span
                class="text-xs font-mono text-zinc-500 group-hover:text-violet-400/70 transition-colors"
                >@Lomzem</span
              >
            </div>
          </a>
          <a
            href="https://github.com/Lomzem/webdev-intro"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-zinc-800/80 bg-zinc-900/50 text-xs font-mono text-zinc-500 hover:text-zinc-400 hover:border-zinc-700 transition-all"
          >
            <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
              <path
                d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
              ></path>
            </svg>
            Lomzem/webdev-intro
          </a>
          <p class="text-[10px] text-zinc-900 mt-3 select-none">
            with a lot of help from opus 4.6
          </p>
        </div>
      </footer>
    </main>
  </div>

  <script is:inline>
    // Sidebar toggle
    var menuToggle = document.getElementById("menu-toggle");
    var sidebar = document.getElementById("sidebar");
    var overlay = document.getElementById("sidebar-overlay");
    var iconOpen = document.getElementById("menu-icon-open");
    var iconClose = document.getElementById("menu-icon-close");
    var sidebarOpen = false;

    function toggleSidebar(open) {
      sidebarOpen = open !== undefined ? open : !sidebarOpen;
      if (sidebarOpen) {
        sidebar.classList.remove("-translate-x-full");
        sidebar.classList.add("translate-x-0");
        overlay.classList.remove("hidden");
        iconOpen.classList.add("hidden");
        iconClose.classList.remove("hidden");
        menuToggle.setAttribute("aria-label", "Close menu");
      } else {
        sidebar.classList.add("-translate-x-full");
        sidebar.classList.remove("translate-x-0");
        overlay.classList.add("hidden");
        iconOpen.classList.remove("hidden");
        iconClose.classList.add("hidden");
        menuToggle.setAttribute("aria-label", "Open menu");
      }
    }

    menuToggle.addEventListener("click", function () {
      toggleSidebar();
    });
    overlay.addEventListener("click", function () {
      toggleSidebar(false);
    });

    // Navigation
    var navButtons = document.querySelectorAll(".nav-btn");
    var sectionIds = Array.from(navButtons).map(function (btn) {
      return btn.dataset.section;
    });

    navButtons.forEach(function (btn) {
      btn.addEventListener("click", function () {
        var id = btn.dataset.section;
        document.getElementById(id).scrollIntoView({ behavior: "smooth" });
        toggleSidebar(false);
      });
    });

    // Scroll tracking with Intersection Observer
    function setActive(id) {
      navButtons.forEach(function (btn) {
        var isActive = btn.dataset.section === id;
        var color = btn.dataset.color;
        var num = btn.querySelector(".nav-num");
        var title = btn.querySelector(".nav-title");
        var dot = btn.querySelector(".nav-dot");

        if (isActive) {
          btn.classList.add("bg-zinc-800/80");
          btn.classList.remove("hover:bg-zinc-900");
          num.style.color = color;
          title.style.color = color;
          dot.style.backgroundColor = color;
          dot.classList.remove("hidden");
        } else {
          btn.classList.remove("bg-zinc-800/80");
          btn.classList.add("hover:bg-zinc-900");
          num.style.color = "#71717a";
          title.style.color = "#a1a1aa";
          dot.classList.add("hidden");
        }
      });
    }

    var observer = new IntersectionObserver(
      function (entries) {
        for (var i = 0; i < entries.length; i++) {
          if (entries[i].isIntersecting) {
            setActive(entries[i].target.id);
          }
        }
      },
      { rootMargin: "-20% 0px -70% 0px" },
    );

    setTimeout(function () {
      sectionIds.forEach(function (id) {
        var el = document.getElementById(id);
        if (el) observer.observe(el);
      });
    }, 100);

    // Set initial active state
    setActive("old-days");
  </script>
</Layout>
